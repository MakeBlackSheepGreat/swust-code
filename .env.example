# SWUST Code Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# LLM Provider API Keys (choose one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
COHERE_API_KEY=
OPENROUTER_API_KEY=

# SWUST Code Configuration
SWUST_CODE_LOCALE=auto
SWUST_CODE_CONFIG_DIR=
SWUST_CODE_DB=
SWUST_CODE_PURE=
SWUST_CODE_MEMORY_RECONCILE_ON_SEARCH=true
SWUST_CODE_MEMORY_SEARCH_SCORE_FLOOR=0.15
